# Virtual environment
backend/venv/
backend/.venv/
venv/
.venv/

# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Distribution / packaging
*.egg-info/
dist/
build/
*.egg

# Environment variables — NEVER commit these
.env
.env.*
*.env
backend/.env
backend/.env.*

# Database files
*.db
*.sqlite
*.sqlite3

# Pytest / coverage
.pytest_cache/
htmlcov/
.coverage
coverage.xml

# MyPy
.mypy_cache/

