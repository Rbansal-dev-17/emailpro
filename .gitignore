# ─────────────────────────────────────────

# Dependencies — install with npm install
frontend/node_modules/
node_modules/

# Vite build output
frontend/dist/
frontend/.vite/

# Local env files
frontend/.env
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

